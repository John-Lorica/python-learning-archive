while True:
    user_input: str = input('You: ').strip()

    if user_input == 'Hello':
        print('Bot: Hello!')
    elif user_input == 'How are you?':
        print('Bot: Good, how about you?')
    elif user_input == 'Lina so big!!!':
        print('Bot: Lina is mine!!!')
    elif user_input == 'Guhbye!':
        print('Bot: Bya!')
    else:
        print('Bot: Sorry, I did not understand that.')